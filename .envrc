# ~/.ai/.envrc

# Load secrets from Infisical
if [ ! -f .env.cached ] || [ $(find .env.cached -mtime +1) ]; then
    infisical export --format=dotenv-export > .env.cached
    echo "export LLM_GEMINI_KEY=$(op read "op://AIScream/1MED Gemini key/password")" >> .env.cached
fi
source .env.cached

# Database URLs (using docker service names)
export DATABASE_URL="postgresql://postgres:${POSTGRES_PASSWORD:-postgres}@postgres:5432/postgres"
export CLICKHOUSE_MIGRATION_URL="clickhouse://clickhouse:9000"
export CLICKHOUSE_URL="http://clickhouse:8123"

# Langfuse (auto-initialized via docker-compose)
export LANGFUSE_HOST="http://langfuse-web:3000"

# OTEL
export OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4318"
