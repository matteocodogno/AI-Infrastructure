# ~/.ai/.env
# This file is sourced by docker-compose
# Secrets should come from Infisical/1Password via .envrc

# Postgres
POSTGRES_VERSION=17
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-postgres}
POSTGRES_DB=postgres

# ClickHouse
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=${CLICKHOUSE_PASSWORD:-clickhouse}

# Redis
REDIS_AUTH=${REDIS_AUTH:-myredissecret}

# LiteLLM
LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY}

# MinIO
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD:-miniosecret}

# S3/MinIO credentials for Langfuse
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD:-miniosecret}
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD:-miniosecret}
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=minio
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD:-miniosecret}

# Langfuse
NEXTAUTH_URL=http://langfuse-web:3000
NEXTAUTH_SECRET=${NEXTAUTH_SECRET}
SALT=${SALT:-mysalt}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
LANGFUSE_USER_PASSWORD=${LANGFUSE_USER_PASSWORD}
DATABASE_URL=${DATABASE_URL}

LANGFUSE_PUBLIC_KEY=${LANGFUSE_PUBLIC_KEY:-}
LANGFUSE_SECRET_KEY=${LANGFUSE_SECRET_KEY:-}

# Telemetry
TELEMETRY_ENABLED=true
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true
